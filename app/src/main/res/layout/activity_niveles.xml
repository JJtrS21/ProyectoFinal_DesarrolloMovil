<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/summer_camp_forest">

    <!-- ========== TÍTULO ========== -->
    <TextView
        android:id="@+id/tvTituloNiveles"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Niveles"
        android:textSize="36sp"
        android:textColor="@color/tertiary_fixed"
        android:fontFamily="@font/fredoka_one"
        android:shadowColor="@color/text_border"
        android:shadowRadius="5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- ========== FLECHA IZQUIERDA ========== -->
    <Button
        android:id="@+id/btnAnterior"
        android:layout_width="70dp"
        android:layout_height="56dp"
        android:text="◀"
        android:textSize="24sp"
        android:backgroundTint="@color/primary"
        android:textColor="@color/on_primary"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnNivelIzquierdo"
        android:layout_marginStart="24dp"
        android:layout_marginTop="80dp"
        android:layout_marginBottom="80dp" />

    <!-- ========== NIVEL IZQUIERDO (CHICO) ========== -->
    <FrameLayout
        android:id="@+id/btnNivelIzquierdo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/circulo_nivel"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnNivelCentral"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="60dp">

        <ImageView
            android:id="@+id/ivNivelIzquierdo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:padding="12dp" />

    </FrameLayout>

    <!-- ========== NIVEL CENTRAL (GRANDE) ========== -->
    <FrameLayout
        android:id="@+id/btnNivelCentral"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/circulo_nivel_central"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/ivNivelCentral"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:padding="20dp" />

    </FrameLayout>

    <!-- ========== NIVEL DERECHO (CHICO) ========== -->
    <FrameLayout
        android:id="@+id/btnNivelDerecho"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/circulo_nivel"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnNivelCentral"
        android:layout_marginStart="12dp"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="60dp">

        <ImageView
            android:id="@+id/ivNivelDerecho"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerInside"
            android:padding="12dp" />

    </FrameLayout>

    <!-- ========== FLECHA DERECHA ========== -->
    <Button
        android:id="@+id/btnSiguiente"
        android:layout_width="70dp"
        android:layout_height="56dp"
        android:text="▶"
        android:textSize="24sp"
        android:backgroundTint="@color/primary"
        android:textColor="@color/on_primary"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="80dp"
        android:layout_marginBottom="80dp" />

    <!-- ========== BOTÓN REGRESAR ========== -->
    <Button
        android:id="@+id/btnRegresarNiveles"
        android:layout_width="65dp"
        android:layout_height="56dp"
        android:text="↩"
        android:textSize="28sp"
        android:backgroundTint="@color/Secondary"
        android:textColor="@color/on_Secondary"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>