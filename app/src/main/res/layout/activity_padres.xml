<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/summer_night_forest"
    tools:context=".Padres">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRegresar"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="18dp"
        android:contentDescription="Regresar"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:text=""
        app:backgroundTint="#6F687C"
        app:cornerRadius="29dp"
        app:icon="@drawable/ic_back_curve"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="34dp"
        app:iconTint="@android:color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp" />

    <com.fei.proyectofinal.OutlinedTextView
        android:id="@+id/tituloPadres"
        android:layout_width="460dp"
        android:layout_height="64dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/fredoka_bold"
        android:gravity="center"
        android:text="Menú Para Padres"
        android:textColor="@android:color/white"
        android:textSize="36sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/zonaIzquierda"
        android:layout_width="270dp"
        android:layout_height="0dp"
        android:layout_marginStart="34dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tituloPadres">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubirPerfiles"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:fontFamily="@font/fredoka_bold"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="48dp"
            android:text="˄"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            app:backgroundTint="#6A4BB3"
            app:cornerRadius="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@android:color/white"
            app:strokeWidth="3dp" />

        <LinearLayout
            android:id="@+id/contenedorPerfiles"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@id/btnBajarPerfiles"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnSubirPerfiles" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBajarPerfiles"
            android:layout_width="72dp"
            android:layout_height="48dp"
            android:fontFamily="@font/fredoka_bold"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="48dp"
            android:text="˅"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            app:backgroundTint="#6A4BB3"
            app:cornerRadius="18dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:strokeColor="@android:color/white"
            app:strokeWidth="3dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/panelDerecho"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="18dp"
        app:cardBackgroundColor="#DDEEEEEE"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/zonaIzquierda"
        app:layout_constraintTop_toBottomOf="@id/tituloPadres">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="34dp"
            android:paddingTop="14dp"
            android:paddingEnd="34dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/txtTituloFormulario"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/fredoka_bold"
                android:gravity="center"
                android:text="Crear Perfil"
                android:textColor="@android:color/black"
                android:textSize="26sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/lblNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/fredoka_bold"
                android:text="Nombre:"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtTituloFormulario" />

            <EditText
                android:id="@+id/edtNombrePerfil"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:backgroundTint="#6A4BB3"
                android:hint="Nombre del perfil"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:singleLine="true"
                android:textColor="@android:color/black"
                android:textColorHint="#777777"
                android:textSize="19sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lblNombre" />

            <TextView
                android:id="@+id/lblFoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/fredoka_bold"
                android:text="Foto:"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/edtNombrePerfil" />

            <ImageView
                android:id="@+id/imgAvatarFormulario"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginBottom="18dp"
                android:contentDescription="Avatar del perfil"
                android:src="@drawable/perfil_a"
                app:layout_constraintBottom_toTopOf="@id/layoutBotonesFormulario"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/lblFoto"
                app:layout_constraintVertical_bias="0.0" />

            <LinearLayout
                android:id="@+id/layoutBotonesFormulario"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="3"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGuardarPerfil"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/fredoka_bold"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="48dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:singleLine="true"
                    android:text="Guardar"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    app:backgroundTint="#6A4BB3"
                    app:cornerRadius="16dp"
                    app:strokeColor="@android:color/white"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelarFormulario"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/fredoka_bold"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="48dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:singleLine="true"
                    android:text="Regresar"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    app:backgroundTint="#6A4BB3"
                    app:cornerRadius="16dp"
                    app:strokeColor="@android:color/white"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEliminarPerfil"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/fredoka_bold"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="48dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:singleLine="true"
                    android:text="Eliminar"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    app:backgroundTint="#9E2A2A"
                    app:cornerRadius="16dp"
                    app:strokeColor="@android:color/white"
                    app:strokeWidth="2dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelHistorial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/txtTituloHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/fredoka_bold"
                    android:gravity="center"
                    android:text="Historial de juego"
                    android:textColor="#4B4350"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="6dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:cardCornerRadius="4dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#6A4BB3"
                    app:strokeWidth="3dp">

                    <TextView
                        android:id="@+id/txtFechaSeleccionada"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="08/17/2025"
                        android:textColor="@android:color/black"
                        android:textSize="16sp" />

                </com.google.android.material.card.MaterialCardView>

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:fillViewport="true">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fillViewport="true">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="26dp"
                                android:background="#D6D6D6"
                                android:gravity="center_vertical"
                                android:paddingStart="8dp"
                                android:text="24 Octubre 2024"
                                android:textColor="@android:color/black"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TableLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#66000000">

                                <TableRow android:background="#CFCFCF">

                                    <TextView android:layout_width="60dp" android:padding="5dp" android:text="Hora" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="110dp" android:padding="5dp" android:text="Tipo" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="115dp" android:padding="5dp" android:text="Operaciones" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="95dp" android:padding="5dp" android:text="Dificultad" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="85dp" android:padding="5dp" android:text="Tiempo" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="85dp" android:padding="5dp" android:text="Aciertos" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />

                                </TableRow>

                                <TableRow android:background="#55FFFFFF">
                                    <TextView android:padding="5dp" android:text="16:30" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Nivel 2" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="+, -, ×" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Medio" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="30 seg" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="7/10" android:textColor="@android:color/black" android:textSize="12sp" />
                                </TableRow>

                                <TableRow android:background="#33FFFFFF">
                                    <TextView android:padding="5dp" android:text="16:15" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Personalizado" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="+" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Fácil" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Sin límite" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="5/5" android:textColor="@android:color/black" android:textSize="12sp" />
                                </TableRow>

                                <TableRow android:background="#55FFFFFF">
                                    <TextView android:padding="5dp" android:text="15:45" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Nivel 1" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="+" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Fácil" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Sin límite" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="8/10" android:textColor="@android:color/black" android:textSize="12sp" />
                                </TableRow>

                            </TableLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="26dp"
                                android:layout_marginTop="12dp"
                                android:background="#D6D6D6"
                                android:gravity="center_vertical"
                                android:paddingStart="8dp"
                                android:text="23 Octubre 2024"
                                android:textColor="@android:color/black"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TableLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#66000000">

                                <TableRow android:background="#CFCFCF">
                                    <TextView android:layout_width="60dp" android:padding="5dp" android:text="Hora" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="110dp" android:padding="5dp" android:text="Tipo" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="115dp" android:padding="5dp" android:text="Operaciones" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="95dp" android:padding="5dp" android:text="Dificultad" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="85dp" android:padding="5dp" android:text="Tiempo" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                    <TextView android:layout_width="85dp" android:padding="5dp" android:text="Aciertos" android:textColor="@android:color/black" android:textSize="12sp" android:textStyle="bold" />
                                </TableRow>

                                <TableRow android:background="#55FFFFFF">
                                    <TextView android:padding="5dp" android:text="18:20" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Nivel 3" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="+, -, ×, ÷" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Difícil" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="45 seg" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="9/10" android:textColor="@android:color/black" android:textSize="12sp" />
                                </TableRow>

                                <TableRow android:background="#33FFFFFF">
                                    <TextView android:padding="5dp" android:text="17:10" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Nivel 1" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="+" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Fácil" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="Sin límite" android:textColor="@android:color/black" android:textSize="12sp" />
                                    <TextView android:padding="5dp" android:text="10/10" android:textColor="@android:color/black" android:textSize="12sp" />
                                </TableRow>

                            </TableLayout>

                        </LinearLayout>

                    </HorizontalScrollView>

                </ScrollView>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>