<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_natural"
    tools:context=".Perfiles">

    <com.fei.proyectofinal.OutlinedTextView
        android:id="@+id/titulo2"
        android:layout_width="251dp"
        android:layout_height="91dp"
        android:fontFamily="@font/fredoka_bold"
        android:gravity="center"
        android:text="@string/aventuras_con_10_n_meros"
        android:textColor="#5B4D68"
        android:textSize="36sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.227"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.306" />

    <com.fei.proyectofinal.OutlinedTextView
        android:id="@+id/titulo1"
        android:layout_width="258dp"
        android:layout_height="51dp"
        android:fontFamily="@font/fredoka_bold"
        android:gravity="center"
        android:text="@string/math_escape"
        android:textColor="#6A4BB3"
        android:textSize="42sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.23"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.13" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPerfil1"
        android:layout_width="150dp"
        android:layout_height="58dp"
        android:fontFamily="@font/fredoka_bold"
        android:text="Perfil 1"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        app:backgroundTint="#6A4BB3"
        app:cornerRadius="12dp"
        app:strokeColor="@android:color/white"
        app:strokeWidth="2dp"
        app:icon="@drawable/perfil_a"
        app:iconTint="@null"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconSize="42dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.72"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.38" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPerfil2"
        android:layout_width="150dp"
        android:layout_height="58dp"
        android:fontFamily="@font/fredoka_bold"
        android:text="Perfil 2"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        app:backgroundTint="#6A4BB3"
        app:cornerRadius="12dp"
        app:strokeColor="@android:color/white"
        app:strokeWidth="2dp"
        app:icon="@drawable/perfil_b"
        app:iconTint="@null"
        app:iconGravity="textStart"
        app:iconPadding="8dp"
        app:iconSize="42dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.72"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.55" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRegresar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text=""
        android:contentDescription="Regresar"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        app:backgroundTint="#6F687C"
        app:cornerRadius="24dp"
        app:icon="@drawable/ic_back_curve"
        app:iconTint="@android:color/white"
        app:iconSize="34dp"
        app:iconPadding="0dp"
        app:iconGravity="textStart"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>