<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fondo_natural"
    tools:context=".Modos">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPerfilSeleccionado"
        android:layout_width="160dp"
        android:layout_height="58dp"
        android:layout_marginStart="28dp"
        android:layout_marginTop="18dp"
        app:cardBackgroundColor="#DDFFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="10dp">

            <ImageView
                android:id="@+id/imgPerfilSeleccionado"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:contentDescription="Imagen del perfil"
                android:src="@drawable/perfil_a" />

            <TextView
                android:id="@+id/txtNombrePerfil"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:fontFamily="@font/fredoka_bold"
                android:singleLine="true"
                android:text="Perfil 1"
                android:textColor="@android:color/black"
                android:textSize="18sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.fei.proyectofinal.OutlinedTextView
        android:id="@+id/tituloModos"
        android:layout_width="430dp"
        android:layout_height="70dp"
        android:layout_marginTop="58dp"
        android:fontFamily="@font/fredoka_bold"
        android:gravity="center"
        android:text="Modos de juego"
        android:textColor="#5B4D68"
        android:textSize="36sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNiveles"
        android:layout_width="250dp"
        android:layout_height="76dp"
        android:layout_marginStart="80dp"
        android:fontFamily="@font/fredoka_bold"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="Niveles"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="25sp"
        app:backgroundTint="#6A4BB3"
        app:cornerRadius="14dp"
        app:icon="@android:drawable/btn_star_big_on"
        app:iconGravity="textStart"
        app:iconPadding="14dp"
        app:iconSize="32dp"
        app:iconTint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnPersonalizado"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tituloModos"
        app:layout_constraintVertical_bias="0.34"
        app:strokeColor="@android:color/white"
        app:strokeWidth="3dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPersonalizado"
        android:layout_width="330dp"
        android:layout_height="76dp"
        android:layout_marginEnd="80dp"
        android:fontFamily="@font/fredoka_bold"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:text="Personalizado"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="25sp"
        app:backgroundTint="#6A4BB3"
        app:cornerRadius="14dp"
        app:icon="@android:drawable/btn_star_big_on"
        app:iconGravity="textStart"
        app:iconPadding="14dp"
        app:iconSize="32dp"
        app:iconTint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="@id/btnNiveles"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnNiveles"
        app:layout_constraintTop_toTopOf="@id/btnNiveles"
        app:strokeColor="@android:color/white"
        app:strokeWidth="3dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRegresar"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_marginStart="28dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Regresar"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:text=""
        app:backgroundTint="#6F687C"
        app:cornerRadius="29dp"
        app:icon="@drawable/ic_back_curve"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="34dp"
        app:iconTint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeWidth="0dp" />

</androidx.constraintlayout.widget.ConstraintLayout>